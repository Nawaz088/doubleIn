# Docker Compose (use service names as hosts)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/doublehq
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/doublehq
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-in-production-this-should-be-very-long-and-random
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=doublehq-files
S3_REGION=us-east-1

APP_ENV=development
APP_NAME=DoubleHQ Clone
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

MAGIC_LINK_BASE_URL=http://localhost:5173
